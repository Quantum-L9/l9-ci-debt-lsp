{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "l9://lsp/activation-pointer/v1",
  "title": "L9 LSP Active Pack Pointer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "pack_version",
    "archive_sha256",
    "corpus_snapshot",
    "compiler_version",
    "taxonomy_version",
    "sdk_contract_version",
    "activated_at",
    "activation_id"
  ],
  "properties": {
    "schema_version": {
      "const": "l9.pack-activation-pointer/v1"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^pack_[0-9a-f]{64}$"
    },
    "pack_version": {
      "type": "string"
    },
    "archive_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "corpus_snapshot": {
      "type": "string",
      "pattern": "^cs_[0-9a-f]{64}$"
    },
    "compiler_version": {
      "type": "string"
    },
    "taxonomy_version": {
      "type": "string"
    },
    "sdk_contract_version": {
      "type": "string"
    },
    "activated_at": {
      "type": "string",
      "format": "date-time"
    },
    "activation_id": {
      "type": "string",
      "pattern": "^activation_[0-9a-f]{64}$"
    }
  }
}
