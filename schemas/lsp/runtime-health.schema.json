{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "l9://lsp/runtime-health/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "workspace_count",
    "open_document_count",
    "running_evaluation_count",
    "queued_evaluation_count",
    "active_pack_id",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "l9.runtime-health/v1"
    },
    "status": {
      "enum": [
        "healthy",
        "degraded",
        "unavailable"
      ]
    },
    "workspace_count": {
      "type": "integer",
      "minimum": 0
    },
    "open_document_count": {
      "type": "integer",
      "minimum": 0
    },
    "running_evaluation_count": {
      "type": "integer",
      "minimum": 0
    },
    "queued_evaluation_count": {
      "type": "integer",
      "minimum": 0
    },
    "active_pack_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
