{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.local/schemas/l9-ci-debt-lsp/compiled_rules.schema.json",
  "title": "L9 CI Debt LSP Compiled Rules",
  "type": "object",
  "required": ["schema_version", "producer", "artifact_name", "generated_at", "rules"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "producer": {"type": "string", "const": "l9-ci-debt-intelligence"},
    "artifact_name": {"type": "string", "const": "ci-debt-intelligence-compiled-rules"},
    "source_run_id": {"type": ["string", "null"]},
    "source_sha": {"type": ["string", "null"]},
    "generated_at": {"type": "string", "minLength": 1},
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/rule"}
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["id", "language", "topology", "severity", "pattern_type", "patterns", "negative_patterns", "message", "source"],
      "additionalProperties": true,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "language": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "enum": ["yaml", "python", "toml", "json", "typescript"]}
        },
        "topology": {"type": "string", "minLength": 1},
        "severity": {"type": "string", "enum": ["error", "warning", "info", "hint"]},
        "pattern_type": {"type": "string", "enum": ["regex"]},
        "patterns": {"type": "array", "items": {"type": "string"}},
        "negative_patterns": {"type": "array", "items": {"type": "string"}},
        "message": {"type": "string", "minLength": 1},
        "quick_fix": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "label": {"type": "string"},
            "insert_after_pattern": {"type": "string"},
            "insert_text": {"type": "string"}
          }
        },
        "source": {"type": "string", "minLength": 1}
      }
    }
  }
}
